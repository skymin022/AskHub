# ── PostgreSQL (단일 인스턴스, auth/app 스키마 분리) ──────────────
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change-me-superuser     # 슈퍼유저(초기화 전용, 운영 시 교체)
POSTGRES_DB=ragdb
POSTGRES_PORT=5432

# 서비스별 DB 계정 (스키마 단위 격리 — 부록 A #15)
AUTH_DB_PASSWORD=change-me-auth           # Spring → auth 스키마 전용
APP_DB_PASSWORD=change-me-app             # Python → app 스키마 전용

# ── 서비스 연동 (후속 단계에서 컨테이너 추가 시 사용) ─────────────
RAGFLOW_API=http://ragflow:9380
RAGFLOW_API_TOKEN=                        # A1: Python 우회 차단용 토큰
OLLAMA_URL=http://ollama:11434
JWKS_URL=http://spring-auth:8080/auth/.well-known/jwks.json
RERANKER_DEVICE=cpu                       # cpu | cuda (§7.4 토글)
